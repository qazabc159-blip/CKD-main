{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ckd-automl-platform.local/schema/model_registry.json",
  "title": "CKD Model Registry",
  "type": "object",
  "required": [
    "registry_version",
    "updated_at",
    "active_model_id",
    "models"
  ],
  "properties": {
    "registry_version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "active_model_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "model_id",
          "version",
          "display_name",
          "status",
          "registered_at",
          "training_dataset",
          "feature_count",
          "response_model_version_base",
          "clinical_adapter_version",
          "local_bundle",
          "s3_bundle"
        ],
        "properties": {
          "model_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "approved",
              "active",
              "retired"
            ]
          },
          "registered_at": {
            "type": "string"
          },
          "registered_by": {
            "type": "string"
          },
          "approved_by": {
            "type": [
              "string",
              "null"
            ]
          },
          "approved_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "approval_note": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_promoted_by": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_promoted_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "promotion_note": {
            "type": [
              "string",
              "null"
            ]
          },
          "training_dataset": {
            "type": "string"
          },
          "feature_count": {
            "type": "integer"
          },
          "route_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "response_model_version_base": {
            "type": "string"
          },
          "clinical_adapter_version": {
            "type": "string"
          },
          "local_bundle": {
            "type": "object",
            "required": [
              "model_path",
              "metadata_path",
              "setup_summary_path"
            ],
            "properties": {
              "model_path": {
                "type": "string"
              },
              "metadata_path": {
                "type": "string"
              },
              "setup_summary_path": {
                "type": "string"
              },
              "manifest_path": {
                "type": "string"
              }
            }
          },
          "s3_bundle": {
            "type": "object",
            "required": [
              "bucket",
              "model_key",
              "metadata_key",
              "setup_summary_key",
              "manifest_key"
            ],
            "properties": {
              "bucket": {
                "type": "string"
              },
              "model_key": {
                "type": "string"
              },
              "metadata_key": {
                "type": "string"
              },
              "setup_summary_key": {
                "type": "string"
              },
              "manifest_key": {
                "type": "string"
              }
            }
          },
          "provenance": {
            "type": "object"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
