{
  "dashboardName": "CKD-Inference-Operational-Dashboard",
  "dashboardBody": {
    "widgets": [
      {
        "type": "text",
        "x": 0,
        "y": 0,
        "width": 24,
        "height": 3,
        "properties": {
          "markdown": "# CKD Inference Operational Dashboard\nMonitors the thesis prototype inference slice: **UI -> API Gateway -> Lambda -> S3 model artifact -> prediction response**. The upper half focuses on service health; the lower half provides route-level evidence through HTTP API access logs and Lambda logs."
        }
      },
      {
        "type": "metric",
        "x": 0,
        "y": 3,
        "width": 12,
        "height": 6,
        "properties": {
          "title": "Lambda invocations, errors, throttles",
          "region": "ap-northeast-1",
          "view": "timeSeries",
          "stacked": false,
          "period": 60,
          "metrics": [
            [
              "AWS/Lambda",
              "Invocations",
              "FunctionName",
              "ckd-inference-stack-CkdInferenceFunction-ljylRibeKzU5",
              {
                "stat": "Sum",
                "label": "Invocations"
              }
            ],
            [
              ".",
              "Errors",
              ".",
              ".",
              {
                "stat": "Sum",
                "label": "Errors",
                "yAxis": "right"
              }
            ],
            [
              ".",
              "Throttles",
              ".",
              ".",
              {
                "stat": "Sum",
                "label": "Throttles",
                "yAxis": "right"
              }
            ]
          ],
          "legend": {
            "position": "bottom"
          }
        }
      },
      {
        "type": "metric",
        "x": 12,
        "y": 3,
        "width": 12,
        "height": 6,
        "properties": {
