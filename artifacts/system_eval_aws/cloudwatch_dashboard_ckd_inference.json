        }
      },
      {
        "type": "metric",
        "x": 12,
        "y": 15,
        "width": 12,
        "height": 6,
        "properties": {
          "title": "API processed data",
          "region": "ap-northeast-1",
          "view": "timeSeries",
          "stacked": false,
          "period": 60,
          "metrics": [
            [
              "AWS/ApiGateway",
              "DataProcessed",
              "ApiId",
              "rrms3q06rb",
              "Stage",
              "prod",
              {
                "stat": "Sum",
                "label": "Data processed"
              }
