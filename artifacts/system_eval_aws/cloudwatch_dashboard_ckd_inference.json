        "properties": {
          "title": "Lambda concurrency",
          "region": "ap-northeast-1",
          "view": "timeSeries",
          "stacked": false,
          "period": 60,
          "metrics": [
            [
              "AWS/Lambda",
              "ConcurrentExecutions",
              "FunctionName",
              "ckd-inference-stack-CkdInferenceFunction-ljylRibeKzU5",
