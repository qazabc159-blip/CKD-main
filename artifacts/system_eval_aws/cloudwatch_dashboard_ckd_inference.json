      },
      {
        "type": "log",
        "x": 0,
        "y": 21,
        "width": 12,
        "height": 8,
        "properties": {
          "title": "Route-level request counts and latency (access logs)",
          "region": "ap-northeast-1",
          "view": "table",
          "query": "SOURCE '/aws/apigateway/ckd-inference-httpapi-access'\n| fields @timestamp, routeKey, status, responseLatency\n| stats count(*) as requests, avg(responseLatency) as avgLatencyMs, max(responseLatency) as maxLatencyMs by routeKey, status\n| sort requests desc"
        }
      },
      {
        "type": "log",
        "x": 12,
        "y": 21,
        "width": 12,
        "height": 8,
        "properties": {
          "title": "Recent API access log entries",
          "region": "ap-northeast-1",
          "view": "table",
          "query": "SOURCE '/aws/apigateway/ckd-inference-httpapi-access'\n| fields @timestamp, routeKey, status, responseLatency, path, sourceIp\n| sort @timestamp desc\n| limit 50"
        }
      },
      {
        "type": "log",
        "x": 0,
        "y": 29,
        "width": 24,
        "height": 8,
        "properties": {
          "title": "Recent Lambda logs",
          "region": "ap-northeast-1",
          "view": "table",
          "query": "SOURCE '/aws/lambda/ckd-inference-stack-CkdInferenceFunction-ljylRibeKzU5'\n| fields @timestamp, @message\n| sort @timestamp desc\n| limit 50"
        }
      }
    ]
  }
