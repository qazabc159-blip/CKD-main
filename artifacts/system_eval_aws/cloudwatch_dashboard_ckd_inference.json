                "stat": "p50",
                "label": "Duration p50"
              }
            ],
            [
              ".",
              "Duration",
              ".",
              ".",
              {
                "stat": "p95",
                "label": "Duration p95"
              }
            ],
            [
              ".",
              "Duration",
              ".",
              ".",
              {
                "stat": "Maximum",
                "label": "Duration max"
              }
            ]
          ],
          "legend": {
            "position": "bottom"
          },
          "yAxis": {
            "left": {
              "label": "Milliseconds"
            }
          }
        }
      },
      {
        "type": "metric",
        "x": 0,
        "y": 9,
        "width": 12,
        "height": 6,
        "properties": {
          "title": "API Gateway request volume and errors",
          "region": "ap-northeast-1",
          "view": "timeSeries",
          "stacked": false,
          "period": 60,
