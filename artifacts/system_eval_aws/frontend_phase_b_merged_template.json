    "CkdInferenceHttpApiStage": {
      "Type": "AWS::ApiGatewayV2::Stage",
      "Properties": {
        "ApiId": {
          "Ref": "CkdInferenceHttpApi"
        },
        "StageName": {
          "Ref": "StageName"
        },
        "Tags": {
          "httpapi:createdBy": "SAM"
        },
        "AutoDeploy": true
      }
    },
    "CkdFrontendSiteBucket": {
      "Type": "AWS::S3::Bucket",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "BucketName": {
          "Fn::If": [
            "HasFrontendBucketName",
            {
              "Ref": "FrontendBucketName"
            },
            {
              "Ref": "AWS::NoValue"
            }
          ]
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "BlockPublicPolicy": true,
          "IgnorePublicAcls": true,
          "RestrictPublicBuckets": true
        },
        "OwnershipControls": {
          "Rules": [
            {
              "ObjectOwnership": "BucketOwnerEnforced"
            }
          ]
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      }
    },
    "CkdFrontendOriginAccessControl": {
      "Type": "AWS::CloudFront::OriginAccessControl",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "OriginAccessControlConfig": {
          "Name": {
            "Fn::Sub": "${AWS::StackName}-ckd-frontend-oac"
          },
          "Description": "Access control for the CKD frontend static site bucket.",
          "OriginAccessControlOriginType": "s3",
          "SigningBehavior": "always",
          "SigningProtocol": "sigv4"
        }
      }
    },
    "CkdFrontendUrlRewriteFunction": {
      "Type": "AWS::CloudFront::Function",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "Name": {
          "Fn::Sub": "${AWS::StackName}-ckd-frontend-rewrite"
        },
        "AutoPublish": true,
        "FunctionConfig": {
          "Comment": "Rewrites directory-style frontend URLs to index.html objects.",
          "Runtime": "cloudfront-js-1.0"
        },
        "FunctionCode": "function handler(event) {\n  var request = event.request;\n  var uri = request.uri;\n\n  if (uri.endsWith('/')) {\n    request.uri = uri + 'index.html';\n    return request;\n  }\n\n  if (!uri.includes('.')) {\n    request.uri = uri + '/index.html';\n  }\n\n  return request;\n}\n"
      }
    },
    "CkdFrontendStaticCachePolicy": {
      "Type": "AWS::CloudFront::CachePolicy",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "CachePolicyConfig": {
          "Name": {
            "Fn::Sub": "${AWS::StackName}-ckd-frontend-static"
          },
          "Comment": "Cache policy for static frontend assets.",
          "DefaultTTL": 3600,
          "MaxTTL": 86400,
          "MinTTL": 0,
          "ParametersInCacheKeyAndForwardedToOrigin": {
            "CookiesConfig": {
              "CookieBehavior": "none"
            },
            "EnableAcceptEncodingBrotli": true,
            "EnableAcceptEncodingGzip": true,
            "HeadersConfig": {
              "HeaderBehavior": "none"
            },
            "QueryStringsConfig": {
              "QueryStringBehavior": "none"
            }
          }
        }
      }
    },
    "CkdFrontendNoCachePolicy": {
      "Type": "AWS::CloudFront::CachePolicy",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "CachePolicyConfig": {
          "Name": {
            "Fn::Sub": "${AWS::StackName}-ckd-frontend-no-cache"
          },
          "Comment": "No-cache policy for HTML and runtime config assets.",
          "DefaultTTL": 0,
          "MaxTTL": 1,
          "MinTTL": 0,
          "ParametersInCacheKeyAndForwardedToOrigin": {
            "CookiesConfig": {
              "CookieBehavior": "none"
            },
            "EnableAcceptEncodingBrotli": true,
            "EnableAcceptEncodingGzip": true,
            "HeadersConfig": {
              "HeaderBehavior": "none"
            },
            "QueryStringsConfig": {
              "QueryStringBehavior": "none"
            }
          }
        }
      }
    },
    "CkdFrontendDistribution": {
      "Type": "AWS::CloudFront::Distribution",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "DistributionConfig": {
          "Enabled": true,
          "HttpVersion": "http2and3",
          "IPV6Enabled": true,
          "PriceClass": {
            "Ref": "FrontendPriceClass"
          },
          "DefaultRootObject": "index.html",
          "Aliases": {
            "Fn::If": [
              "UseFrontendCustomDomain",
              [
                {
                  "Ref": "FrontendDomainName"
                }
              ],
              {
                "Ref": "AWS::NoValue"
              }
            ]
          },
          "Origins": [
            {
              "Id": "frontendS3Origin",
              "DomainName": {
                "Fn::GetAtt": [
                  "CkdFrontendSiteBucket",
                  "RegionalDomainName"
                ]
              },
              "S3OriginConfig": {},
              "OriginAccessControlId": {
                "Fn::GetAtt": [
                  "CkdFrontendOriginAccessControl",
                  "Id"
                ]
              }
            }
          ],
          "DefaultCacheBehavior": {
            "TargetOriginId": "frontendS3Origin",
            "ViewerProtocolPolicy": "redirect-to-https",
            "AllowedMethods": [
              "GET",
              "HEAD",
              "OPTIONS"
            ],
            "CachedMethods": [
              "GET",
              "HEAD",
              "OPTIONS"
            ],
            "Compress": true,
            "CachePolicyId": {
              "Ref": "CkdFrontendStaticCachePolicy"
            },
            "FunctionAssociations": [
              {
                "EventType": "viewer-request",
                "FunctionARN": {
                  "Fn::GetAtt": [
                    "CkdFrontendUrlRewriteFunction",
                    "FunctionMetadata.FunctionARN"
                  ]
                }
              }
            ]
          },
          "CacheBehaviors": [
            {
              "PathPattern": "*.html",
              "TargetOriginId": "frontendS3Origin",
              "ViewerProtocolPolicy": "redirect-to-https",
              "AllowedMethods": [
                "GET",
                "HEAD",
                "OPTIONS"
              ],
              "CachedMethods": [
                "GET",
                "HEAD",
                "OPTIONS"
              ],
              "Compress": true,
              "CachePolicyId": {
                "Ref": "CkdFrontendNoCachePolicy"
              }
            },
            {
              "PathPattern": "app/config.js",
              "TargetOriginId": "frontendS3Origin",
              "ViewerProtocolPolicy": "redirect-to-https",
              "AllowedMethods": [
                "GET",
                "HEAD",
                "OPTIONS"
              ],
              "CachedMethods": [
                "GET",
                "HEAD",
                "OPTIONS"
              ],
              "Compress": true,
              "CachePolicyId": {
                "Ref": "CkdFrontendNoCachePolicy"
              }
            },
            {
              "PathPattern": "DEPLOY_VERSION.txt",
              "TargetOriginId": "frontendS3Origin",
              "ViewerProtocolPolicy": "redirect-to-https",
              "AllowedMethods": [
                "GET",
                "HEAD",
                "OPTIONS"
              ],
              "CachedMethods": [
                "GET",
                "HEAD",
                "OPTIONS"
              ],
              "Compress": true,
              "CachePolicyId": {
                "Ref": "CkdFrontendNoCachePolicy"
              }
            }
          ],
          "ViewerCertificate": {
            "Fn::If": [
              "UseFrontendCustomDomain",
              {
                "AcmCertificateArn": {
                  "Ref": "FrontendCertificateArn"
                },
                "MinimumProtocolVersion": "TLSv1.2_2021",
                "SslSupportMethod": "sni-only"
              },
              {
                "CloudFrontDefaultCertificate": true
              }
            ]
          }
        }
      }
    },
    "CkdFrontendBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Condition": "FrontendHostingEnabled",
      "Properties": {
        "Bucket": {
          "Ref": "CkdFrontendSiteBucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowCloudFrontServicePrincipalReadOnly",
              "Effect": "Allow",
              "Principal": {
                "Service": "cloudfront.amazonaws.com"
              },
              "Action": [
                "s3:GetObject"
              ],
              "Resource": {
                "Fn::Sub": "${CkdFrontendSiteBucket.Arn}/*"
              },
              "Condition": {
                "StringEquals": {
                  "AWS:SourceArn": {
                    "Fn::Sub": "arn:${AWS::Partition}:cloudfront::${AWS::AccountId}:distribution/${CkdFrontendDistribution}"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "CkdFrontendDnsRecordSetGroup": {
      "Type": "AWS::Route53::RecordSetGroup",
      "Condition": "CreateFrontendDnsRecord",
      "Properties": {
        "HostedZoneId": {
          "Ref": "FrontendHostedZoneId"
        },
        "RecordSets": [
          {
            "Name": {
              "Ref": "FrontendDomainName"
            },
            "Type": "A",
            "AliasTarget": {
              "HostedZoneId": "Z2FDTNDATAQYW2",
              "DNSName": {
                "Fn::GetAtt": [
                  "CkdFrontendDistribution",
                  "DomainName"
                ]
              },
              "EvaluateTargetHealth": false
            }
          },
          {
            "Name": {
              "Ref": "FrontendDomainName"
            },
            "Type": "AAAA",
            "AliasTarget": {
              "HostedZoneId": "Z2FDTNDATAQYW2",
              "DNSName": {
                "Fn::GetAtt": [
                  "CkdFrontendDistribution",
                  "DomainName"
                ]
              },
              "EvaluateTargetHealth": false
            }
          }
        ]
      }
    }
  },
  "Conditions": {
    "UseS3Artifacts": {
      "Fn::And": [
        {
          "Fn::Not": [
            {
              "Fn::Equals": [
                {
                  "Ref": "ModelArtifactBucket"
                },
                ""
              ]
            }
          ]
        },
        {
          "Fn::Not": [
            {
              "Fn::Equals": [
                {
                  "Ref": "ModelArtifactKey"
                },
                ""
              ]
            }
          ]
        }
      ]
    },
    "FrontendHostingEnabled": {
      "Fn::Equals": [
        {
          "Ref": "EnableFrontendHosting"
        },
        "true"
      ]
    },
    "HasFrontendBucketName": {
      "Fn::Not": [
        {
          "Fn::Equals": [
            {
              "Ref": "FrontendBucketName"
            },
            ""
          ]
        }
      ]
    },
    "HasFrontendDomainName": {
      "Fn::Not": [
        {
          "Fn::Equals": [
            {
              "Ref": "FrontendDomainName"
            },
            ""
          ]
        }
      ]
    },
    "HasFrontendCertificateArn": {
      "Fn::Not": [
        {
          "Fn::Equals": [
            {
              "Ref": "FrontendCertificateArn"
            },
            ""
          ]
        }
      ]
    },
    "HasFrontendHostedZoneId": {
      "Fn::Not": [
        {
          "Fn::Equals": [
            {
              "Ref": "FrontendHostedZoneId"
            },
            ""
          ]
        }
      ]
    },
    "UseFrontendCustomDomain": {
      "Fn::And": [
        {
          "Condition": "FrontendHostingEnabled"
        },
        {
          "Condition": "HasFrontendDomainName"
        },
        {
          "Condition": "HasFrontendCertificateArn"
        }
      ]
    },
    "CreateFrontendDnsRecord": {
      "Fn::And": [
        {
          "Condition": "UseFrontendCustomDomain"
        },
        {
          "Condition": "HasFrontendHostedZoneId"
        }
      ]
    }
  }
}
