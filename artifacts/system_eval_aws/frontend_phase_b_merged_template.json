{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Minimal API Gateway + Lambda inference slice for the CKD Prediction Studio. This first version focuses on the thesis-critical serving path rather than full MLOps automation.\n",
  "Parameters": {
    "StageName": {
      "Type": "String",
      "Default": "prod",
      "Description": "HTTP API stage name."
    },
    "AllowedOrigin": {
      "Type": "String",
      "Default": "*",
      "Description": "Allowed browser origin for CORS."
    },
    "LambdaMemorySize": {
      "Type": "Number",
      "Default": 3008,
      "MinValue": 1024,
      "Description": "Memory size for the inference Lambda container."
    },
    "LambdaTimeout": {
      "Type": "Number",
      "Default": 29,
      "MinValue": 3,
      "MaxValue": 29,
      "Description": "Lambda timeout in seconds. HTTP API should stay below 30 seconds."
    },
    "ModelArtifactBucket": {
      "Type": "String",
      "Default": "",
      "Description": "Optional S3 bucket containing the serving artifact bundle."
    },
    "ModelArtifactKey": {
      "Type": "String",
      "Default": "",
      "Description": "Optional S3 object key for best_autoprognosis_model.pkl."
    },
    "ModelMetadataKey": {
      "Type": "String",
      "Default": "",
      "Description": "Optional S3 object key for best_autoprognosis_metadata.json."
    },
    "SetupSummaryKey": {
      "Type": "String",
      "Default": "",
      "Description": "Optional S3 object key for setup_summary.json."
    },
    "EnableFrontendHosting": {
      "Type": "String",
      "Default": "false",
      "AllowedValues": [
        "true",
        "false"
      ],
      "Description": "Whether to provision AWS-native static frontend hosting resources."
    },
    "FrontendBucketName": {
      "Type": "String",
      "Default": "",
      "Description": "Optional S3 bucket name for the frontend static site. Leave blank to let CloudFormation generate one."
    },
    "FrontendPriceClass": {
      "Type": "String",
      "Default": "PriceClass_200",
      "AllowedValues": [
        "PriceClass_100",
        "PriceClass_200",
        "PriceClass_All"
      ],
      "Description": "CloudFront price class for the frontend distribution."
    },
    "FrontendDomainName": {
      "Type": "String",
      "Default": "",
      "Description": "Optional custom domain name for the frontend distribution."
    },
    "FrontendCertificateArn": {
      "Type": "String",
      "Default": "",
      "Description": "Optional ACM certificate ARN in us-east-1 for the frontend custom domain."
    },
    "FrontendHostedZoneId": {
      "Type": "String",
      "Default": "",
      "Description": "Optional Route 53 hosted zone ID used to create alias records for the frontend custom domain."
    }
  },
  "Outputs": {
    "HttpApiBaseUrl": {
      "Description": "Base URL for the CKD inference HTTP API.",
      "Value": {
        "Fn::Sub": "https://${CkdInferenceHttpApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}/${StageName}"
      }
    },
    "HealthUrl": {
      "Description": "Health endpoint URL.",
      "Value": {
        "Fn::Sub": "https://${CkdInferenceHttpApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}/${StageName}/health"
      }
    },
    "PredictResearchUrl": {
      "Description": "Research inference route.",
      "Value": {
        "Fn::Sub": "https://${CkdInferenceHttpApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}/${StageName}/predict/research"
      }
    },
    "PredictClinicalUrl": {
      "Description": "Clinical inference route.",
      "Value": {
        "Fn::Sub": "https://${CkdInferenceHttpApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}/${StageName}/predict/clinical"
      }
    },
    "FrontendBucketName": {
      "Condition": "FrontendHostingEnabled",
      "Description": "S3 bucket name for the AWS-native frontend static site.",
      "Value": {
        "Ref": "CkdFrontendSiteBucket"
      }
    },
    "FrontendDistributionId": {
      "Condition": "FrontendHostingEnabled",
      "Description": "CloudFront distribution ID for the frontend static site.",
      "Value": {
        "Ref": "CkdFrontendDistribution"
      }
    },
    "FrontendDistributionDomainName": {
      "Condition": "FrontendHostingEnabled",
      "Description": "CloudFront domain name for the frontend static site.",
      "Value": {
        "Fn::GetAtt": [
          "CkdFrontendDistribution",
          "DomainName"
        ]
      }
    },
    "FrontendUrl": {
      "Condition": "FrontendHostingEnabled",
      "Description": "Primary frontend URL.",
      "Value": {
        "Fn::If": [
          "UseFrontendCustomDomain",
          {
            "Fn::Sub": "https://${FrontendDomainName}"
          },
          {
            "Fn::Sub": "https://${CkdFrontendDistribution.DomainName}"
          }
        ]
      }
    }
  },
  "Resources": {
    "CkdInferenceFunctionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": [
                  "lambda.amazonaws.com"
                ]
              },
              "Action": [
                "sts:AssumeRole"
              ]
            }
          ]
        },
        "ManagedPolicyArns": [
          {
            "Fn::Sub": "arn:${AWS::Partition}:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
          }
        ]
      },
      "Metadata": {
        "SamResourceId": "CkdInferenceFunctionRole"
      }
    },
    "CkdInferenceS3ReadPolicy": {
      "Type": "AWS::IAM::Policy",
      "Condition": "UseS3Artifacts",
      "Properties": {
        "PolicyName": "ckd-inference-s3-read",
        "Roles": [
          {
            "Ref": "CkdInferenceFunctionRole"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "ReadArtifactBundle",
              "Effect": "Allow",
              "Action": [
                "s3:GetObject"
              ],
              "Resource": [
                {
                  "Fn::Sub": "arn:${AWS::Partition}:s3:::${ModelArtifactBucket}/*"
                }
              ]
            }
          ]
        }
      },
      "Metadata": {
        "SamResourceId": "CkdInferenceS3ReadPolicy"
      }
    },
    "CkdInferenceFunction": {
      "Type": "AWS::Lambda::Function",
      "Metadata": {
        "DockerContext": "C:\\Users\\User\\Desktop\\????\\????\\??????\\CKD-main",
        "DockerTag": "ckd-inference-v1",
        "Dockerfile": "infra/lambda_inference/Dockerfile",
        "SamResourceId": "CkdInferenceFunction"
      },
      "Properties": {
        "Code": {
          "ImageUri": "098890538524.dkr.ecr.ap-northeast-1.amazonaws.com/ckdinferencestackaf8ef839/ckdinferencefunctione5454474repo:ckdinferencefunction-562991f7c9c8-ckd-inference-v1"
        },
        "PackageType": "Image",
        "MemorySize": {
          "Ref": "LambdaMemorySize"
        },
        "Role": {
          "Fn::GetAtt": [
            "CkdInferenceFunctionRole",
            "Arn"
          ]
        },
        "Timeout": {
          "Ref": "LambdaTimeout"
        },
        "Environment": {
          "Variables": {
            "CKD_ALLOWED_ORIGIN": {
              "Ref": "AllowedOrigin"
            },
            "CKD_MODEL_ARTIFACT_BUCKET": {
              "Ref": "ModelArtifactBucket"
            },
            "CKD_MODEL_ARTIFACT_KEY": {
              "Ref": "ModelArtifactKey"
            },
            "CKD_MODEL_METADATA_KEY": {
              "Ref": "ModelMetadataKey"
            },
            "CKD_SETUP_SUMMARY_KEY": {
              "Ref": "SetupSummaryKey"
            },
            "MPLCONFIGDIR": "/tmp/matplotlib",
            "JOBLIB_TEMP_FOLDER": "/tmp/joblib",
            "OMP_NUM_THREADS": "1",
            "OPENBLAS_NUM_THREADS": "1",
            "MKL_NUM_THREADS": "1",
            "NUMEXPR_NUM_THREADS": "1"
          }
        },
        "Tags": [
          {
            "Key": "lambda:createdBy",
            "Value": "SAM"
          }
        ],
        "Architectures": [
          "x86_64"
        ]
      }
    },
    "CkdInferenceFunctionHealthRoutePermission": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "Action": "lambda:InvokeFunction",
        "FunctionName": {
          "Ref": "CkdInferenceFunction"
        },
        "Principal": "apigateway.amazonaws.com",
        "SourceArn": {
          "Fn::Sub": [
            "arn:${AWS::Partition}:execute-api:${AWS::Region}:${AWS::AccountId}:${__ApiId__}/${__Stage__}/GET/health",
            {
              "__ApiId__": {
                "Ref": "CkdInferenceHttpApi"
              },
              "__Stage__": "*"
            }
          ]
        }
      }
    },
